source "https://rubygems.org"

# Match what GitHub Pages serves so local previews match production.
# See https://pages.github.com/versions/ for the current GH Pages versions.
gem "github-pages", group: :jekyll_plugins

# Plugins explicitly enabled in _config.yml (the github-pages gem ships
# them but Jekyll still needs them listed somewhere).
group :jekyll_plugins do
  gem "jekyll-theme-minimal"
end

# Required on Ruby 3+
gem "webrick", "~> 1.8"
